{
  "name": "mia-live-4-0",
  "version": "4.0.0",
  "description": "MIA – AI-følgesvend",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron:dev": "electron .",
    "electron:build": "electron-builder --win --x64",
    "test": "echo \"No tests specified\" && exit 0"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "groq-sdk": "^0.9.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "grunt": "^1.6.1"
  },
  "build": {
    "appId": "com.mia.companion",
    "productName": "MIA",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "index.html",
      "script.js",
      "styles.css",
      "assets/**/*",
      "server.js"
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "MIA"
    }
  }
}
